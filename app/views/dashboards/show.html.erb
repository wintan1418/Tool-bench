<section>
  <div style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
    <div>
      <div class="tb-eyebrow">Dashboard</div>
      <h1 class="tb-h1" style="font-size: 44px; margin-top: 10px;">Your stuff.</h1>
      <div class="tb-mono tb-muted" style="margin-top: 8px; font-size: 13px;">
        signed in as <%= current_user.email_address %>
      </div>
    </div>
    <div style="display: flex; gap: 8px;">
      <%= link_to "New invoice", new_invoice_path, class: "tb-btn tb-btn-ghost" %>
      <%= link_to "New board",   down_path,        class: "tb-btn tb-btn-ghost" %>
      <%= button_to "Sign out",  session_path, method: :delete, class: "tb-btn tb-btn-quiet", form: { style: "display:inline;" } %>
    </div>
  </div>

  <div class="tb-tool-layout" style="grid-template-columns: 1.3fr 1fr; gap: 28px; margin-top: 28px;">
    <div class="tb-stack-20">
      <section>
        <div class="tb-section-title">
          <h2 class="tb-h2" style="font-size: 22px;">Invoices</h2>
          <span class="tb-eyebrow"><%= @invoices.size %> saved</span>
        </div>
        <% if @invoices.any? %>
          <div class="tb-card">
            <% @invoices.each do |inv| %>
              <div class="tb-file-row" style="grid-template-columns: 1fr 90px 110px 90px 60px;">
                <div>
                  <div class="tb-file-name"><%= inv.number %><span class="tb-mono tb-muted" style="font-weight:400; margin-left: 10px; font-size: 11px;"><%= inv.to_name.presence || "—" %></span></div>
                  <div class="tb-file-meta">created <%= time_ago_in_words(inv.created_at) %> ago · template: <%= inv.template %></div>
                </div>
                <span class="tb-pill tb-pill-neu"><%= inv.template %></span>
                <span class="tb-mono" style="font-size: 13px;"><%= inv.currency %> <%= number_with_delimiter((inv.total_cents || 0).to_f.round(2)) %></span>
                <%= link_to "Edit", edit_invoice_path(slug: inv.slug), class: "tb-btn tb-btn-ghost", style: "height: 30px; padding: 0 10px; font-size: 12px;" %>
                <%= button_to "×", invoice_path(slug: inv.slug),
                      method: :delete,
                      form: { data: { turbo_confirm: "Delete this invoice?" }, style: "display:inline;" },
                      class: "tb-btn-icon" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No invoices yet. Create one in the invoice maker." %>
        <% end %>
      </section>

      <section>
        <div class="tb-section-title">
          <h2 class="tb-h2" style="font-size: 22px;">Uptime boards</h2>
          <span class="tb-eyebrow"><%= @boards.size %> saved</span>
        </div>
        <% if @boards.any? %>
          <div class="tb-card">
            <% @boards.each do |b| %>
              <div class="tb-file-row" style="grid-template-columns: 1fr 140px 80px;">
                <div>
                  <div class="tb-file-name"><%= b.name %></div>
                  <div class="tb-file-meta"><%= b.hosts.size %> hosts · /down/b/<%= b.slug %></div>
                </div>
                <span class="tb-mono tb-muted" style="font-size: 11px;"><%= time_ago_in_words(b.created_at) %> ago</span>
                <%= link_to "Open", board_path(slug: b.slug), class: "tb-btn tb-btn-ghost", style: "height: 30px; padding: 0 10px; font-size: 12px;" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No uptime boards yet." %>
        <% end %>
      </section>

      <section>
        <div class="tb-section-title">
          <h2 class="tb-h2" style="font-size: 22px;">URL sets</h2>
          <span class="tb-eyebrow"><%= @url_sets.size %> saved</span>
        </div>
        <% if @url_sets.any? %>
          <div class="tb-card">
            <% @url_sets.each do |s| %>
              <div class="tb-file-row" style="grid-template-columns: 1fr 140px 80px;">
                <div>
                  <div class="tb-file-name"><%= s.name %></div>
                  <div class="tb-file-meta"><%= s.urls.size %> URLs · /o/<%= s.slug %></div>
                </div>
                <span class="tb-mono tb-muted" style="font-size: 11px;"><%= time_ago_in_words(s.created_at) %> ago</span>
                <%= link_to "Open", url_set_path(slug: s.slug), class: "tb-btn tb-btn-ghost", style: "height: 30px; padding: 0 10px; font-size: 12px;" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No saved URL sets yet." %>
        <% end %>
      </section>
    </div>

    <aside class="tb-stack-14">
      <div class="tb-card tb-card-pad">
        <div class="tb-eyebrow" style="color: var(--tb-green); margin-bottom: 8px;">By design</div>
        <div class="tb-text-sm">
          <strong>HEIC, PDF tools, Image compress and Sign PDF don't appear here.</strong>
          They run entirely in your browser — we never see what you converted, merged, or signed.
          That negative space is the whole point of this suite.
        </div>
      </div>

      <div class="tb-card tb-card-pad">
        <div class="tb-eyebrow" style="margin-bottom: 8px;">Shortcuts</div>
        <div class="tb-stack-10">
          <%= link_to "→ Make an invoice",    new_invoice_path, class: "tb-mono" %>
          <%= link_to "→ New uptime board",   down_path,        class: "tb-mono" %>
          <%= link_to "→ New URL set",        open_urls_path,   class: "tb-mono" %>
          <%= link_to "→ Sign a PDF",         sign_path,        class: "tb-mono" %>
        </div>
      </div>
    </aside>
  </div>
</section>
